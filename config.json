{
    "UseService": false,
    "DistanceFilter": 750,
    "InitialNotificationContent": "Waiting for location updates",
    "Prompt": "Write a short, engaging overview about <place>. Keep it fact-based, but feel free to use a relaxed and conversational tone. Focus on the most interesting and important points first. Include information about <focus>. Ignore <ignore>. Surround all names of people with <b></b> and all location names with <c></c>. No need for headers and titles. When you refer to the place, no need to mention the state and country.",
    "PromptSuffix": "If relevant, highlight what makes <place> different from <previous_place>. Avoid repeating details already mentioned: <previous_answer>.",
    "MinToConsiderPreviousAnswer": 15,
    "Model": "gpt-4.1-mini",
    "Temperature": 0.1,
    "MaxCompletionTokens": 1500,
    "RemoveLastParagraph": ["No-Overall", "No-In conclusion", "No-In summary"],
    "ShowPlaceAndPersonLinks": true,
    "PlaceLink": "https://www.bing.com/search?q=",
    "PersonLink": "https://www.bing.com/search?q=",
    "Interests": {
        "Festivals": true,
        "Famous People": true,
        "History": true,
        "Landmarks": true,
        "Local Cuisine": true,
        "Museums": true,
        "Parks": true,
        "Population": true,
        "Shopping": true,
        "Industries": true
    },
    "SystemMessageShowBefore": "",
    "SystemMessage": "",
    "ShowAds": true,
    "ShowAffiliateLinks": true,
    "FreeLocations": 20,
    "IAPSku": "roadtripedia_locations_50x_0.49",
    "SkuLocationsToAdd": 50,
    "LocationsBuyThreshold": 150,
    "EnableLocationsCount": false,
    "PhotoSearchUrl": "https://www.bing.com/images/search?q=",
    "ImgRegExp": "<div[^>]*class=\"img_cont hoff\"[^>]*>(.*?)<img[^>]*src=\"([^\"]+)\"",
    "RegExpGroup": 2,
    "CheckAppUpdate": true,
    "DaysToNextAppUpdateDialog": 3,
    "LogErrors": true
}
